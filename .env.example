# Database (used by docker-compose for postgres service)
DATABASE_URL=postgresql://payload:payload@postgres:5432/slides
POSTGRES_DB=slides
POSTGRES_USER=payload
POSTGRES_PASSWORD=change-me-in-production

# Payload CMS
PAYLOAD_SECRET=generate-a-random-secret-here

# AI — LiteLLM proxy (OpenAI-compatible, routes to Claude via OpenRouter)
OPENAI_BASE_URL=https://llm.klarc.eu/v1
OPENAI_API_KEY=your-litellm-api-key

# Google OAuth (admin login)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Optional
NEXT_TELEMETRY_DISABLED=1
