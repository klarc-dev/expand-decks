# Database (used by docker-compose for postgres service)
DATABASE_URL=postgresql://payload:payload@postgres:5432/slides
POSTGRES_DB=slides
POSTGRES_USER=payload
POSTGRES_PASSWORD=change-me-in-production

# Payload CMS
PAYLOAD_SECRET=generate-a-random-secret-here

# AI — any OpenAI-compatible endpoint (OpenAI direct, LiteLLM proxy, OpenRouter…)
# OPENAI_MODEL must be a model name that endpoint serves
# (e.g. gpt-5-mini for OpenAI — cheap and good for drafting —
#  or openrouter/anthropic/claude-sonnet-4.6 for the LiteLLM proxy)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your-openai-or-proxy-api-key
OPENAI_MODEL=gpt-5-mini

# Google OAuth (admin login)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Dev server port + URL. PORT is a hardcoded uncommon port so it never collides
# with 3000; `pnpm dev` frees it before starting. NEXT_PUBLIC_SERVER_URL MUST
# match PORT — Payload's CSRF check compares the request Origin to serverURL, and
# a mismatch silently nulls req.user (writes 403, admin "must be logged in").
PORT=4317
NEXT_PUBLIC_SERVER_URL=http://localhost:4317

# Seed admin — optional. If both are set, payload.config onInit upserts this
# admin on every boot (creates if missing, otherwise resets password + role).
# Leave unset in production unless you want a guaranteed admin login.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me

# Optional
NEXT_TELEMETRY_DISABLED=1
