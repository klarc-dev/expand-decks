# Database (used by docker-compose for postgres service)
DATABASE_URL=postgresql://payload:payload@postgres:5432/slides
POSTGRES_DB=slides
POSTGRES_USER=payload
POSTGRES_PASSWORD=change-me-in-production

# Payload CMS
PAYLOAD_SECRET=generate-a-random-secret-here

# AI — any OpenAI-compatible endpoint (OpenAI direct, LiteLLM proxy, OpenRouter…)
# OPENAI_MODEL must be a model name that endpoint serves
# (e.g. gpt-5-mini for OpenAI — cheap and good for drafting —
#  or openrouter/anthropic/claude-sonnet-4.6 for the LiteLLM proxy)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your-openai-or-proxy-api-key
OPENAI_MODEL=gpt-5-mini

# Google OAuth (admin login)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Optional
NEXT_TELEMETRY_DISABLED=1
